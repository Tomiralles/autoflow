# Supabase (proyecto > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email transaccional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# UltraMsg (WhatsApp) — credenciales por defecto de la plataforma;
# cada negocio puede tener las suyas en businesses.whatsapp_*
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# Webhook token para /api/whatsapp/incoming (recibe mensajes de UltraMsg)
# Generar: openssl rand -hex 32. En el panel de UltraMsg la URL del webhook
# lleva el token como query param: .../api/whatsapp/incoming?token=XXX
WHATSAPP_WEBHOOK_TOKEN=

# Negocio al que se atribuyen los mensajes entrantes de la instancia de
# plataforma (compartida entre negocios, no identifica al remitente).
# Los negocios con instancia UltraMsg PROPIA se resuelven solos por
# whatsapp_instance_id y no necesitan esto.
WHATSAPP_DEFAULT_BUSINESS_ID=

# Cron de Vercel: Vercel envía "Authorization: Bearer <CRON_SECRET>"
# automáticamente a las rutas de vercel.json si esta variable existe
# en el proyecto de Vercel. Las rutas /api/cron/* la verifican.
CRON_SECRET=

# URL pública de la app (para enlaces en emails y .ics)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email del administrador de la plataforma: recibe el aviso diario de
# suscripciones por vencer (cron de automations). Vacío = sin avisos.
ADMIN_EMAIL=
